# Databricks workspace
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# SQL warehouse for DDL and state queries
DATABRICKS_WAREHOUSE_ID=abc123def456

# Unity Catalog settings — this is the app's own CONTROL-PLANE catalog/schema
# (projects, approvals, alerts, etc.), created automatically by `python -m
# db.setup` if it doesn't exist yet.
MLOPS_CATALOG=mlops
MLOPS_SCHEMA=mlops

# Optional: Default Storage workspaces require a MANAGED LOCATION to create
# catalogs via SQL/API. Leave unset for a plain CREATE CATALOG (works on
# workspaces that already have a default location configured).
# MLOPS_MANAGED_LOCATION=

# Optional: the catalog PROJECT schemas live in (not the control-plane
# catalog/schema above) — defaults to MLOPS_CATALOG if unset.
# MLOPS_PROJECTS_CATALOG=mlops

# Optional: per-environment catalog overrides for PROJECT schemas. Owner
# request 2026-07-13: dev/staging work happens in a separate non-prod
# catalog; prod stays in MLOPS_PROJECTS_CATALOG (or MLOPS_CATALOG if that's
# unset too). Each project still gets its own schema inside whichever
# catalog applies ({project_name}_dev / _staging / _prod) — only the
# catalog changes. Leave unset to keep everything in one catalog (today's
# default).
# MLOPS_PROJECTS_CATALOG_DEV=mlops_non_prod
# MLOPS_PROJECTS_CATALOG_STAGING=mlops_non_prod
# MLOPS_PROJECTS_CATALOG_PROD=mlops

# GitHub (for repo auto-creation). Token needs the `repo` and `workflow`
# scopes ONLY — confirmed live 2026-07-13 that `delete_repo` is NOT needed
# (and deliberately not requested: this app never deletes a GitHub repo or
# its contents, only creates/updates files and — separately — reminds a
# human to delete/archive when a project is removed).
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org

# Optional: when linking an EXISTING repo in Step 1 instead of creating a
# new one, the app pushes into it only if "empty" — root-level entries
# matching one of these names are ignored (comma-separated; common org
# automation stamps a README/LICENSE/.github in at repo-creation time).
# Leave unset for the default list shown here.
# MLOPS_EMPTY_REPO_IGNORE_PATTERNS=README.md,.gitignore,LICENSE,.github

# Optional: Databricks foundation model endpoint for LLM suggestions
DATABRICKS_LLM_ENDPOINT=databricks-meta-llama-3-1-70b-instruct

# Optional: Notification Delivery Service — unset channels report
# not_configured rather than failing (alerts/approvals/HITL escalation)
MLOPS_SMTP_HOST=
MLOPS_SMTP_PORT=587
MLOPS_SMTP_USER=
MLOPS_SMTP_PASSWORD=
MLOPS_SMTP_FROM_EMAIL=
MLOPS_SLACK_WEBHOOK_URL=
MLOPS_TEAMS_WEBHOOK_URL=

# Optional: Budget Policy attribution (serverless-only — this app is
# serverless-first, §17.1, so every generated job/serving endpoint qualifies).
# These are ACCOUNT-level credentials, not workspace ones — a materially
# higher-privilege credential than everything else in this file. Creating and
# managing budget policies requires an account-level OAuth service principal;
# a workspace PAT (DATABRICKS_TOKEN above) cannot do this. Leave unset to
# disable budget-policy attribution entirely — the app degrades gracefully.
# https://docs.databricks.com/aws/en/admin/usage/budget-policies
DATABRICKS_ACCOUNT_HOST=https://accounts.azuredatabricks.net
DATABRICKS_ACCOUNT_ID=
DATABRICKS_ACCOUNT_CLIENT_ID=
DATABRICKS_ACCOUNT_CLIENT_SECRET=

# Optional: pre-existing default budget policy id (used as-is if set).
# If left blank, the app creates/reuses one named MLOPS_DEFAULT_BUDGET_POLICY_NAME.
MLOPS_DEFAULT_BUDGET_POLICY_ID=
MLOPS_DEFAULT_BUDGET_POLICY_NAME=mlops-control-plane-default

# Optional: control-plane cost thresholds (what THIS app's own usage costs,
# not any individual project's). Placeholder defaults ($50/$100 per month)
# until you set a real number — the Portfolio Analytics page marks these
# PLACEHOLDER in the UI rather than presenting them as real limits.
MLOPS_CONTROL_PLANE_BUDGET_WARN=50
MLOPS_CONTROL_PLANE_BUDGET_CRIT=100

# Optional: Model Serving endpoint count alert threshold. No per-workspace
# limit is published by Databricks; this is an internally-set alert
# threshold, not a hard ceiling.
MLOPS_CAPACITY_ENDPOINT_WARN_THRESHOLD=50
