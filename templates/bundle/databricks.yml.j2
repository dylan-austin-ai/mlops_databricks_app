bundle:
  name: {{ project_name }}

include:
  - resources/*.yml

# Schema-per-project convention (owner decision 2026-07-07): every project
# gets one schema per environment inside a configurable catalog. The catalog
# is config on the control plane (MLOPS_PROJECTS_CATALOG, with optional
# per-env overrides) — flipping to catalog-per-env later is a config change.
variables:
  catalog:
    description: Catalog holding this project's schemas (schema-per-project convention)
    default: {{ catalog_dev }}
  schema:
    description: Project-scoped schema inside the catalog
    default: {{ project_name }}_dev

permissions:
  - level: CAN_MANAGE
    user_name: {{ owner_email }}

targets:
  dev:
    default: true
    workspace:
      host: {{ workspace_host }}
    variables:
      catalog: {{ catalog_dev }}
      schema: {{ project_name }}_dev

  staging:
    workspace:
      host: {{ workspace_host }}
    variables:
      catalog: {{ catalog_staging }}
      schema: {{ project_name }}_staging

  prod:
    mode: production
    workspace:
      host: {{ workspace_host }}
      root_path: /Workspace/Shared/.bundle/${bundle.name}/${bundle.target}
    run_as:
      user_name: {{ owner_email }}
    variables:
      catalog: {{ catalog_prod }}
      schema: {{ project_name }}_prod
