def run_search(x_train, y_train, x_valid, y_valid, n_trials: int = 50):
    import optuna

    study = optuna.create_study(direction="maximize")
    study.optimize(
        lambda trial: objective(trial, x_train, y_train, x_valid, y_valid),
        n_trials=n_trials,
    )
    print(f"Best trial #{study.best_trial.number}: value={study.best_value}, params={study.best_params}")
    return study


