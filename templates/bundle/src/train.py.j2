        # feature table{% if adhoc_features %} ({{ adhoc_features|join(", ") }}){% endif %}.
{% if training_datasets %}
        base_df = spark.table("{{ training_datasets[0] }}")
{% else %}
        base_df = spark.table(f"{catalog}.{schema}.your_training_table")
{% endif %}

        training_set = fe.create_training_set(
            df=base_df,
            feature_lookups=feature_lookups,
            label="{{ target_variable }}",
