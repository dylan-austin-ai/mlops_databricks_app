def train(catalog: str, schema: str, model_name: str, retrain: bool = False) -> None:
    import mlflow

    mlflow.set_registry_uri("databricks-uc")
    uc_model = f"{catalog}.{schema}.{model_name}"

    with mlflow.start_run():
        mlflow.set_tag("project_id", model_name)
        mlflow.set_tag("run_type", "retrain" if retrain else "train")
{% if feature_lookups %}
