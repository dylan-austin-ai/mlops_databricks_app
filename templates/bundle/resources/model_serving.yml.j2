resources:
  model_serving_endpoints:
    {{ project_name }}_endpoint:
      name: {{ project_name }}-${bundle.target}
      # Governance-by-default (§9.1): route optimization can only be enabled at
      # endpoint creation — never retrofittable — so it must be right on first deploy.
      route_optimized: {{ 'true' if route_optimized else 'false' }}
{% if budget_policy_id %}
      # [Public Preview] serverless-only cost attribution — confirmed live
      # against CLI v{{ cli_version }} bundle schema
      budget_policy_id: {{ budget_policy_id }}
{% endif %}
      config:
        served_entities:
          - name: champion
            entity_name: ${var.catalog}.${var.schema}.{{ project_name }}
            entity_version: "{{ champion_version }}"
        traffic_config:
          routes:
            - served_model_name: champion
              traffic_percentage: 100
{% if inference_capture %}
      ai_gateway:
        inference_table_config:
          enabled: true
          catalog_name: ${var.catalog}
          schema_name: ${var.schema}
          table_name_prefix: inference_log
{% endif %}
      tags:
        - key: project_id
          value: {{ project_name }}
        - key: team
          value: {{ team_name }}
        - key: managed_by
          value: mlops_control_plane
